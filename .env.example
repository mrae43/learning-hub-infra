# Postgres+pgvector connection URL.
DATABASE_URL=postgresql+psycopg2://learning_hub:learning_hub@localhost:5432/learning_hub

# OpenAI API key for embeddings (and inference later).
OPENAI_API_KEY=sk-...

# Active embedding model. MVP uses 1536-dim models only (ADR-0014).
EMBEDDING_MODEL=text-embedding-3-small

# HNSW query-time candidate list size.
HNSW_EF_SEARCH=40

# Maximum upload size in bytes (placeholder).
MAX_UPLOAD_BYTES=104857600

# Allowed file extensions (placeholder).
ALLOWED_FILE_EXTENSIONS=["pdf"]
